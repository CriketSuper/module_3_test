# The checker is started on HQ-CLI.

# Linux hosts.
HQ_SRV_IP=192.168.1.10
BR_SRV_IP=192.168.3.10
LINUX_SSH_USER=sshuser
LINUX_SSH_PASSWORD=P@ssw0rd
LINUX_SSH_PORT=2026

# ISP.
ISP_IP=172.16.1.1
ISP_SSH_USER=sshuser
ISP_SSH_PASSWORD=P@ssw0rd
ISP_SSH_PORT=22

# EcoRouter.
HQ_RTR_SSH_HOST=172.16.1.4
BR_RTR_SSH_HOST=172.16.2.5
HQ_RTR_WAN_IP=172.16.1.4
BR_RTR_WAN_IP=172.16.2.5
ROUTER_SSH_USER=net_admin
ROUTER_SSH_PASSWORD=P@ssw0rd
ROUTER_SSH_PORT=22
ROUTER_ENABLE_PASSWORD=

# Domain user import.
DOMAIN_FQDN=au-team.irpo
CSV_FILE=/iso/Users.csv

# PKI and HTTPS.
WEB_DOMAIN=web.au-team.irpo
DOCKER_DOMAIN=docker.au-team.irpo
CERT_DAYS=30
CA_COMMON_NAME="AU-Team CA"
AUTH_USER=WEB
AUTH_PASSWORD=P@ssw0rd

# GRE over IPsec.
IPSEC_PROFILE=VPN
CRYPTO_MAP=VPN-MAP
VPN_FILTER_MAP=VPN-FILTER
TUNNEL_INTERFACE=tunnel.0

# Firewall.
FIREWALL_MAP=INTERNET_IN
WAN_INTERFACE=int0
ALLOWED_TCP_PORTS="22 8080 2026"

# CUPS.
CUPS_SERVER_PORT=631
CUPS_SERVER_QUEUE=Cups-PDF
CUPS_CLIENT_QUEUE=HQ-PDF

# Rsyslog and rotation.
LOG_ROOT=/opt
LOG_FILE_NAME=messages.log
LOG_SERVER_PORT=514
LOG_PROTOCOL=tcp
LOG_HOSTS="HQ-RTR BR-RTR BR-SRV"
ROTATE_SIZE=10M

# Monitoring.
MON_DOMAIN=mon.au-team.irpo
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
NODE_EXPORTER_PORT=9100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=P@ssw0rd

# Ansible inventory reports.
ANSIBLE_DIR=/etc/ansible
INVENTORY_PLAYBOOK=inventory.yml
INVENTORY_REPORT_DIR=PC-INFO
HQ_CLI_IP=192.168.2.10

# Fail2ban.
FAIL2BAN_SSH_PORT=2026
FAIL2BAN_MAX_RETRY=3
FAIL2BAN_FIND_TIME=600
FAIL2BAN_BAN_TIME=60

# Install missing diagnostic packages on HQ-CLI.
AUTO_INSTALL=yes
